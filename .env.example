# Copy this file to .env.local for local dev, and add the real value
# in Vercel's Project Settings → Environment Variables for production.

# Lead form (Make webhook)
MAKE_WEBHOOK_URL=https://hook.us1.make.com/your-webhook-id-here

# Break Life Cycle form (direct Airtable)
# Create a Personal Access Token at https://airtable.com/create/tokens
# with scopes: data.records:read, data.records:write — and grant access
# to the "Headline Break Tracking" base.
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=
